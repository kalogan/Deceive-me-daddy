{
  "name": "deceive",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "lint:content": "tsx scripts/lint-content.ts",
    "check:boot": "tsx --tsconfig packages/server/tsconfig.json scripts/check-boot.ts",
    "test": "vitest run",
    "build": "pnpm -r build",
    "gate": "bash scripts/gate.sh"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vitest": "^2.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
